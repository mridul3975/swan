---
// src/components/FeatureSection.astro
import { ButtonLink } from './ui/button';
const { title, description, imgSrc, imgAlt, imageSide = 'right' } = Astro.props;
const isReversed = imageSide === 'left';
---
<section class="feature-section" class:list={{ 'bg-light': true }}>
    <div class="container feature-container" class:list={{ 'is-reversed': isReversed }}>
        <div class="feature-content">
            <h2>{title}</h2>
            <p>{description}</p>
            <ButtonLink href="#" variant="link" size="lg" className="feature-link">Start Free Planning &rarr;</ButtonLink>
            <div class="quote">
                <blockquote>
                    "I was introduced to Scripbox by my friend and since then there is no looking back. One of the best apps for beginners who want to explore mutual funds. Simple and easy to use."
                </blockquote>
                <cite><strong>Priya Sharma</strong>, Scripbox investor</cite>
            </div>
        </div>
        <div class="feature-image">
            <img src={imgSrc} alt={imgAlt}>
        </div>
    </div>
</section>

<style>
    .feature-section {
        padding: 6rem 0;
    }
    .bg-light {
        background-color: var(--bg-light);
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
    }
    .feature-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }
    .is-reversed {
        grid-template-columns: 40% 60%;
    }
    .is-reversed .feature-image {
        order: -1;
    }
    h2 {
        font-size: 2.2rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }
    p {
        color: var(--text-light);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }
    .feature-link {
        display: inline-block;
        margin-bottom: 2rem;
    }
    .quote {
        border-left: 3px solid var(--brand-orange);
        padding-left: 1.5rem;
    }
    blockquote {
        font-style: italic;
        color: var(--text-light);
        margin-bottom: 1rem;
    }
    cite {
        font-style: normal;
        font-size: 0.9rem;
    }
    .feature-image img {
        max-width: 320px;
        margin: 0 auto;
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.15);
        border-radius: 20px;
    }

    /* Responsive for Features */
    @media (max-width: 768px) {
        .feature-container, .is-reversed {
            grid-template-columns: 1fr;
        }
        .is-reversed .feature-image {
            order: 1; /* Reset order */
        }
        .feature-image {
            margin-top: 2rem;
        }
    }
</style>