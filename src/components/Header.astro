---
import { motion } from 'framer-motion';
import { ButtonLink } from './ui/button';
---
<header class="site-header flex justify-center gap-2">
            <a href="#home" class="logo">
                <motion.img
                    client:idle
                    src="/logo.jpg"
                    alt="Swan Logo"
                    whileHover={{ scale: 1.2 }}
                    transition={{ duration: 0.1, ease: "easeInOut" }}
                />
            </a>
    <div class="container nav-container flex justify-center items-center gap-4">
        <a></a>
        <nav>
            <ul>
                <motion.li client:idle whileHover={{ rotate: 30 }} transition={{ duration: 0.09, ease: "easeInOut" }}>
                    <a href="#home">Home</a>
                </motion.li>
                <motion.li client:idle whileHover={{ rotate: 30 }} transition={{ duration: 0.09, ease: "easeInOut" }}>
                    <a href="#learn">Learn</a>
                </motion.li>
                <motion.li client:idle whileHover={{ rotate: 30 }} transition={{ duration: 0.09, ease: "easeInOut" }}>
                    <a href="#about">About Us</a>
                </motion.li>
            </ul>
        </nav>
        <nav>
        <div class="actions">
            <motion.div client:idle whileHover={{ scale: 1.02 }} transition={{ duration: 0.1, ease: "easeInOut" }}>
                <ButtonLink href="#newsletter" variant="ghost" size="sm">Contact Us</ButtonLink>
            </motion.div>
        </div>
        </nav>
 
    </div>
</header>

<style>
    header {
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--border-color);
    }
    .nav-container {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
    }
    .logo img {
        height: 6rem;
    }
    nav {
        display: flex;
        justify-content: center;
        gap: 1rem;
    }
    nav ul {
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        list-style: none;
    }
    nav a {
        font-size: 1.2rem;
        color: var(--text-light);
        font-weight: 500;
        transition: color 0.3s ease;
    }
    nav a:hover {
        color: var(--color-gray-600);
    }
    
    .actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding-right: 1rem;
    }
    .actions a,
    .actions button {
        background: var(--brand-orange);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.85rem 1.25rem;
        font-weight: 600;
        text-decoration: none;
    }
    .actions a:hover,
    .actions button:hover {
        opacity: 0.95;
    }
    /* Simple responsive for nav - a full hamburger menu is more complex */
    @media (max-width: 992px) {
        .nav-container {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
        }
        nav {
            display: block;
            width: 100%;
        }
        nav ul {
            flex-direction: column;
            gap: 1rem;
            align-items: center;
            justify-content: center;
            margin: 1rem 0 0;
        }
        .actions {
            justify-content: center;
            width: 100%;
            margin-top: 1rem;
            
        }
    }
</style>