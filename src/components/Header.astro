---
import { ButtonLink } from './ui/button';
---
<header class="site-header flex justify-between ">
    <div class="container nav-container flex justify-between">
        <a href="#home" class="logo">
            <img src="/logo.jpg" alt="Swan Logo">
        </a>
        <nav>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#learn">Learn</a></li>
                <li><a href="#about">About Us</a></li>
            </ul>
        </nav>
        <div class="actions">
            <ButtonLink href="#newsletter" variant="ghost" size="sm">Contact Us</ButtonLink>
        </div>
    </div>
</header>

<style>
    header {
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--border-color);
    }
    .nav-container {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
    }
    .logo img {
        height: 6rem;
    }
    nav {
        display: flex;
        justify-content: center;
    }
    nav ul {
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        list-style: none;
    }
    nav a {
        font-size: 1.2rem;
        color: var(--text-light);
        font-weight: 500;
        transition: color 0.3s ease;
    }
    nav a:hover {
        color: var(--brand-orange);
    }
    .actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    /* Simple responsive for nav - a full hamburger menu is more complex */
    @media (max-width: 992px) {
        .nav-container {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
        }
        nav {
            display: block;
            width: 100%;
        }
        nav ul {
            flex-direction: column;
            gap: 1rem;
            align-items: center;
            justify-content: center;
            margin: 1rem 0 0;
        }
        .actions {
            justify-content: center;
            width: 100%;
            margin-top: 1rem;
        }
    }
</style>