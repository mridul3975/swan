---
// src/pages/index.astro
import BaseLayout from '../components/BaseLayout.astro';
import FeatureSection from '../components/FeatureSection.astro';
import Header from '../components/Header.astro';
import { ButtonLink } from '../components/ui/button';
---


<BaseLayout title="Scripbox - Invest in the best mutual funds">
    <Header />
    
    <main>
        <!-- HERO SECTION -->
        <section class="hero-section">
            <div class="container hero-container">
                <div class="hero-content">
                    <span class="eyebrow">Get complete investment advice in Scripbox app</span>
                    <h1>
                        Grow wealth.<br>
                        Achieve goals.<br>
                        Invest in the best mutual funds.
                    </h1>
                    <p class="hero-copy">Scripbox helps you invest with confidence using expert recommendations, simplified planning, and continuous tracking.</p>
                    <div class="hero-actions">
                        <ButtonLink href="#" size="lg" className="primary-btn">App Store</ButtonLink>
                        <ButtonLink href="#" variant="outline" size="lg" className="secondary-btn">Play Store</ButtonLink>
                    </div>
                    <div class="hero-stats">
                        <div>
                            <strong>1 lakh</strong>
                            <span>Families</span>
                        </div>
                        <div>
                            <strong>2,500</strong>
                            <span>Cities</span>
                        </div>
                        <div>
                            <strong>20,000 Cr</strong>
                            <span>Wealth</span>
                        </div>
                    </div>
                </div>
                <div class="hero-image">
                    <img src="/imgs/Hero Phone Mockup.jpg" alt="Scripbox app on a phone">
                </div>
            </div>
        </section>

        <section class="trust-bar">
            <div class="container trust-grid">
                <div>
                    <span>Trusted by over</span>
                    <strong>1 lakh Indians</strong>
                </div>
                <div>
                    <span>Investment strategies shaped by expert advisors and data-backed insights.</span>
                </div>
            </div>
        </section>

        <section class="feature-cards">
            <div class="container cards-grid">
                <article class="card">
                    <h3>Grow wealth.</h3>
                    <p>Clients who started investing with Scripbox have built meaningful long-term wealth through disciplined financial planning.</p>
                    <ButtonLink href="#" variant="link" size="lg">Start investing &rarr;</ButtonLink>
                </article>
                <article class="card">
                    <h3>Achieve goals.</h3>
                    <p>Create a plan for your family’s future with personalised recommendations, goal tracking, and clear next steps.</p>
                    <ButtonLink href="#" variant="link" size="lg">Get personalised plan &rarr;</ButtonLink>
                </article>
                <article class="card">
                    <h3>Invest in the best funds.</h3>
                    <p>Scripbox recommends high-quality mutual funds with strong risk-adjusted performance and long-term focus.</p>
                    <ButtonLink href="#" variant="link" size="lg">See plan options &rarr;</ButtonLink>
                </article>
            </div>
        </section>

        <FeatureSection
            title="Grow wealth."
            description="Scripbox helps you select the right mix of funds to grow your wealth steadily. We continuously monitor and manage your portfolio to keep it on track."
            imgSrc="/imgs/Feature 1 Phone Mockup.jpg"
            imgAlt="Grow wealth screen"
            imageSide="right"
        />

        <section class="cta-section">
            <div class="container cta-card">
                <div>
                    <p class="section-label">Regular or Direct? Choice is yours.</p>
                    <h2>Build wealth with expert mutual fund planning.</h2>
                </div>
                <ButtonLink href="#" size="lg" className="cta-btn">See Pricing Options &rarr;</ButtonLink>
            </div>
        </section>

        <section class="funds-section">
            <div class="container">
                <div class="section-header">
                    <div>
                        <span>Best Mutual Funds</span>
                        <h2>Create wealth by investing in mutual funds.</h2>
                    </div>
                    <ButtonLink href="#" variant="outline" size="lg">Start investing &rarr;</ButtonLink>
                </div>
                <div class="fund-grid">
                    <article class="fund-card">
                        <h4>HDFC Growth Fund</h4>
                        <p>Fund selection curated by expert advisors for long-term growth.</p>
                        <strong>+21.4% CAGR</strong>
                    </article>
                    <article class="fund-card">
                        <h4>ICICI Prudential</h4>
                        <p>Balanced equity portfolio with strong historical performance.</p>
                        <strong>+17.9% CAGR</strong>
                    </article>
                    <article class="fund-card">
                        <h4>SBI Large Cap</h4>
                        <p>Reliable large-cap exposure for steady portfolio returns.</p>
                        <strong>+16.1% CAGR</strong>
                    </article>
                </div>
            </div>
        </section>

        <section class="newsletter-section">
            <div class="container newsletter-card">
                <div>
                    <span>Stay informed with market insights always.</span>
                    <h2>Subscribe and follow us if you haven’t already.</h2>
                </div>
                <div class="newsletter-actions">
                    <input type="email" placeholder="Enter email address" aria-label="Email address" />
                    <ButtonLink href="#" size="lg">Subscribe</ButtonLink>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
:root {
    --brand-orange: #f97316;
    --brand-green: #059669;
    --bg-light: #f8fafc;
    --card-bg: #ffffff;
    --surface: #f8fafc;
    --text-light: #64748b;
}

.hero-section {
    padding: 5rem 0 2rem;
}
.hero-container {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    align-items: center;
    gap: 2.5rem;
}
.eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--brand-orange);
}
.hero-content h1 {
    font-size: clamp(3rem, 4vw, 4.5rem);
    line-height: 0.95;
    max-width: 680px;
    margin-bottom: 1.5rem;
}
.hero-copy {
    max-width: 620px;
    margin-bottom: 2rem;
    color: var(--text-light);
    line-height: 1.8;
}
.hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
}
.primary-btn,
.secondary-btn,
.cta-btn {
    min-width: 180px;
}
.hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding: 1.5rem 0 0;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
}
.hero-stats div {
    display: flex;
    flex-direction: column;
}
.hero-stats strong {
    font-size: 1.6rem;
    font-weight: 700;
}
.hero-stats span {
    color: var(--text-light);
    margin-top: 0.35rem;
}
.hero-image {
    display: flex;
    justify-content: center;
}
.hero-image img {
    width: 100%;
    max-width: 520px;
    border-radius: 28px;
    box-shadow: 0 40px 100px rgba(15, 23, 42, 0.12);
}

.trust-bar {
    padding: 1.75rem 0;
    background: rgba(255, 255, 255, 0.75);
    border-top: 1px solid rgba(15, 23, 42, 0.05);
    border-bottom: 1px solid rgba(15, 23, 42, 0.05);
}
.trust-grid {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
}
.trust-grid span,
.trust-grid strong {
    display: block;
}
.trust-grid strong {
    font-size: 1.5rem;
}

.feature-cards {
    padding: 4rem 0;
}
.cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
}
.card {
    background: var(--card-bg);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.04);
}
.card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
}
.card p {
    margin-bottom: 1.5rem;
    color: var(--text-light);
    line-height: 1.8;
}

.cta-section {
    padding: 3rem 0;
}
.cta-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    background: linear-gradient(90deg, rgba(255,255,255,1) 0%, rgba(255,243,236,1) 100%);
    border: 1px solid rgba(249, 115, 22, 0.15);
    border-radius: 24px;
    padding: 2rem 2.5rem;
}
.section-label {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    color: var(--brand-orange);
    margin-bottom: 0.75rem;
}
.cta-card h2 {
    font-size: 2rem;
    max-width: 680px;
    margin: 0;
}

.funds-section {
    padding: 4rem 0;
    background: var(--bg-light);
}
.section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
}
.section-header span {
    display: block;
    color: var(--text-light);
    margin-bottom: 0.5rem;
}
.section-header h2 {
    font-size: 2rem;
    margin: 0;
}
.fund-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
}
.fund-card {
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 1.75rem;
}
.fund-card h4 {
    margin-bottom: 0.85rem;
}
.fund-card p {
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
}
.fund-card strong {
    font-size: 1.1rem;
    color: var(--brand-green);
}

.newsletter-section {
    padding: 4rem 0 6rem;
}
.newsletter-card {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
    align-items: center;
    background: #111827;
    color: white;
    border-radius: 28px;
    padding: 2.5rem;
}
.newsletter-card span {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    opacity: 0.85;
}
.newsletter-card h2 {
    margin: 0.75rem 0 0;
    font-size: 2rem;
    line-height: 1.2;
}
.newsletter-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
}
.newsletter-actions input {
    flex: 1;
    min-width: 240px;
    border: none;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    font-size: 1rem;
}

@media (max-width: 1080px) {
    .hero-container,
    .newsletter-card,
    .cta-card,
    .section-header {
        grid-template-columns: 1fr;
    }
    .trust-grid,
    .cards-grid,
    .fund-grid {
        grid-template-columns: 1fr;
    }
    .cta-card,
    .newsletter-card {
        text-align: center;
    }
    .newsletter-actions {
        justify-content: center;
    }
}

@media (max-width: 768px) {
    .hero-section { padding-top: 3.5rem; }
    .hero-content h1 { font-size: 2.8rem; }
    .hero-stats { justify-content: center; }
    .hero-image img { max-width: 100%; }
}
</style>