---
import BaseLayout from '../components/BaseLayout.astro';
import FeatureSection from '../components/FeatureSection.astro';
import Header from '../components/Header.astro';
import { ButtonLink } from '../components/ui/button';
---


<BaseLayout title="Swan - Invest in the best mutual funds">
    <Header />
    
    <main>
        <svg style="display: none;" aria-hidden="true">
            <filter id="grain-filter">
                <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
                <feColorMatrix type="saturate" values="0" />
                <feComponentTransfer>
                    <feFuncR type="linear" slope="0.5" />
                    <feFuncG type="linear" slope="0.5" />
                    <feFuncB type="linear" slope="0.5" />
                </feComponentTransfer>
            </filter>
        </svg>
        <!-- HERO SECTION -->
        <section id="home" class="hero-section mx-auto max-w-7xl justify-center">
            <div class="container hero-container">
                <div class="hero-content">
                    <span class="eyebrow">Get complete investment advice in Swan </span>
                    <h1 class="heading-underline">
                        Grow wealth.<br>
                        Achieve goals.<br>
                        Invest in the best mutual funds.
                    </h1>
                    <p class="hero-copy">Swan helps you invest with confidence using expert recommendations, simplified planning, and continuous tracking.</p>
                    <div class="hero-actions">
                        <ButtonLink href="#" size="lg" className="primary-btn">App Store</ButtonLink>
                        <ButtonLink href="#" variant="outline" size="lg" className="secondary-btn">Play Store</ButtonLink>
                    </div>
                    <div class="hero-stats">
                        <div>
                            <strong>1 lakh</strong>
                            <span>Families</span>
                        </div>
                        <div>
                            <strong>2,500</strong>
                            <span>Cities</span>
                        </div>
                        <div>
                            <strong>20,000 Cr</strong>
                            <span>Wealth</span>
                        </div>
                    </div>
                </div>
                <div class="hero-image">
                    <img src="/imgs/Hero Phone Mockup.jpg" alt="Swan app on a phone">
                </div>
            </div>
        </section>


        <section id="learn" class="feature-cards">
            <div class="container cards-grid">
                <article class="card">
                    <h3 class="heading-underline">Grow wealth.</h3>
                    <p>Clients who started investing with Swan have built meaningful long-term wealth through disciplined financial planning.</p>
                    <ButtonLink href="#" variant="link" size="lg">Start investing &rarr;</ButtonLink>
                </article>
                <article class="card">
                    <h3 class="heading-underline">Achieve goals.</h3>
                    <p>Create a plan for your family’s future with personalised recommendations, goal tracking, and clear next steps.</p>
                    <ButtonLink href="#" variant="link" size="lg">Get personalised plan &rarr;</ButtonLink>
                </article>
                <article class="card">
                    <h3 class="heading-underline">Invest in the best funds.</h3>
                    <p>Swan recommends high-quality mutual funds with strong risk-adjusted performance and long-term focus.</p>
                    <ButtonLink href="#" variant="link" size="lg">See plan options &rarr;</ButtonLink>
                </article>


            </div>

                        <div class="container cta-card">
                <div>
                    <p class="section-label">Regular or Direct? Choice is yours.</p>
                    <h2 class="heading-underline">Build wealth with expert mutual fund planning.</h2>
                </div>
                <ButtonLink href="#" size="lg" className="cta-btn">See Pricing Options &rarr;</ButtonLink>
            </div>
        </section>

        <!-- FeatureSection removed here; moved into CTA section -->

        <section class="cta-section">

            <!-- Moved growth feature content from FeatureSection into CTA page -->
            <section class="feature-section moved-feature grain-background">
                <div class="container feature-container">
                    <div class="feature-content">
                        <h2 class="heading-underline">Grow wealth.</h2>
                        <p>Swan helps you select the right mix of funds to grow your wealth steadily. We continuously monitor and manage your portfolio to keep it on track.</p>
                        <ButtonLink href="#" variant="link" size="lg" className="feature-link">Start Free Planning &rarr;</ButtonLink>
                        <div class="quote">
                            <blockquote>
                                "I was introduced to Swan by my friend and since then there is no looking back. One of the best apps for beginners who want to explore mutual funds. Simple and easy to use."
                            </blockquote>
                            <cite><strong>Priya Sharma</strong>, Swan investor</cite>
                        </div>
                    </div>
                    <div class="feature-image">
                        <img src="/imgs/Feature 1 Phone Mockup.jpg" alt="Grow wealth screen">
                    </div>
                </div>
            </section>
        </section>

        <section class="funds-section">
            <div class="container">
                <div class="section-header">
                    <div>
                        <span>Best Mutual Funds</span>
                        <h2 class="heading-underline">Create wealth by investing in mutual funds.</h2>
                    </div>
                    <ButtonLink href="#" variant="outline" size="lg">Start investing &rarr;</ButtonLink>
                </div>
                <div class="fund-grid">
                    <article class="fund-card">
                        <h4>HDFC Growth Fund</h4>
                        <p>Fund selection curated by expert advisors for long-term growth.</p>
                        <strong>+21.4% CAGR</strong>
                    </article>
                    <article class="fund-card">
                        <h4>ICICI Prudential</h4>
                        <p>Balanced equity portfolio with strong historical performance.</p>
                        <strong>+17.9% CAGR</strong>
                    </article>
                    <article class="fund-card">
                        <h4>SBI Large Cap</h4>
                        <p>Reliable large-cap exposure for steady portfolio returns.</p>
                        <strong>+16.1% CAGR</strong>
                    </article>
                </div>
            </div>
        </section>

        <section id="newsletter" class="newsletter-section">
            <div class="container newsletter-card">
                <div>
                    <span>Stay informed with market insights always.</span>
                    <h2 class="heading-underline">Subscribe and follow us if you haven’t already.</h2>
                </div>
                <div class="newsletter-actions">
                    <input type="email" placeholder="Enter email address" aria-label="Email address" />
                    <ButtonLink href="#" size="lg">Subscribe</ButtonLink>
                </div>
            </div>
        </section>

        <footer id="about" class="site-footer">
            <div class="container footer-top">
                <div class="social-group">
                    <span>Follow us on</span>
                    <div class="social-links">
                        <a href="#" aria-label="Twitter">Twitter</a>
                        <a href="#" aria-label="Facebook">Facebook</a>
                        <a href="#" aria-label="LinkedIn">LinkedIn</a>
                    </div>
                </div>
            </div>
            <div class="container footer-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Disclosures</a>
                <a href="#">Terms & Conditions</a>
                <a href="#">Security</a>
                <a href="#">Disclaimer</a>
                <a href="#">Grievance Redressal</a>
                <a href="#">Sitemap</a>
            </div>
            <div class="container footer-copy">
                <p>Corporate Office : Wilshire III by MFAR, 5th Floor, 492, Hobli, RHB Colony, Mahadevapura, Bengaluru, Karnataka 560048</p>
                <p>Mutual Fund investments are subject to market risks. Please read all scheme related documents carefully before investing. Past performance is not an indicator of future returns.</p>
            </div>
        </footer>
    </main>
</BaseLayout>

<style>
:root {
    --brand-orange: #f97316;
    --brand-green: #059669;
    --bg-light: #f8fafc;
    --card-bg: #ffffff;
    --surface: #f8fafc;
    --text-light: #64748b;
}

html,
body {
    height: 100%;
    margin: 0;
}

.container {
    width: min(100%, 80rem);
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
}

main {
    min-height: 100vh;
    overflow: visible;
    scroll-behavior: auto;
    overscroll-behavior: contain;
}

main::-webkit-scrollbar {
    width: 0;
    height: 0;
}

main {
    -ms-overflow-style: none;
    scrollbar-width: none;
}

.hero-section {
    padding: 4.5rem 0 2.5rem;
}
.hero-container {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    gap: 2.25rem;
    max-width: 1160px;
    margin: 0 auto;
}
.hero-content {
    max-width: 620px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.eyebrow {
    display: inline-flex;
    margin-bottom: 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--brand-orange);
}
.hero-content h1 {
    font-size: clamp(3rem, 4vw, 4.5rem);
    line-height: 0.95;
    max-width: 640px;
    margin-bottom: 1.5rem;
}
.hero-copy {
    max-width: 600px;
    margin-bottom: 2rem;
    color: var(--text-light);
    line-height: 1.8;
}
.hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
}
.primary-btn,
.secondary-btn,
.cta-btn {
    min-width: 220px;
    padding: 1rem 1.75rem;
    font-size: 1rem;
}
.hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    padding: 1.5rem 0 0;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
}
.hero-stats div {
    display: flex;
    flex-direction: column;
}
.hero-stats strong {
    font-size: 1.5rem;
    font-weight: 700;
}
.hero-stats span {
    color: var(--text-light);
    margin-top: 0.35rem;
}
.hero-image {
    display: flex;
    justify-content: center;
}
.hero-image img {
    width: 100%;
    max-width: 600px;
}

.feature-section.moved-feature {
    padding: 3rem 0 0;
    background: rgba(248, 250, 252, 0.95);
    position: relative;
    overflow: hidden;
}
.feature-section.moved-feature.grain-background {
    background-color: var(--bg-light);
}
.feature-section.moved-feature.grain-background::before {
    content: "";
    position: absolute;
    inset: 0;
    filter: url(#grain-filter);
    opacity: 0.15;
    pointer-events: none;
}
.feature-section.moved-feature .feature-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 2rem;
    align-items: center;
    max-width: 1120px;
    margin: 0 auto;
}
.feature-section.moved-feature .feature-content {
    max-width: 520px;
    margin: 0;
}
.feature-section.moved-feature .feature-image {
    display: flex;
    justify-content: center;
}
.feature-section.moved-feature .feature-image img {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.12);
}
.feature-section.moved-feature h2 {
    font-size: 3rem;
    margin-bottom: 1rem;
}
.feature-section.moved-feature p {
    color: var(--text-light);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
}
.feature-section.moved-feature .feature-link {
    display: inline-block;
    margin-bottom: 2rem;
        font-size: 1.15rem;

}
.feature-section.moved-feature .quote {
    border-left: 3px solid var(--brand-orange);
    padding-left: 1.25rem;
    font-size: 1.1rem;
    margin-bottom: 4rem;


}

.trust-bar {
    padding: 1.75rem 0;
    background: rgba(255, 255, 255, 0.75);
    border-top: 1px solid rgba(15, 23, 42, 0.05);
    border-bottom: 1px solid rgba(15, 23, 42, 0.05);
}
.trust-grid {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
}
.trust-grid span,
.trust-grid strong {
    display: block;
}
.trust-grid strong {
    font-size: 1.5rem;
}

.feature-cards {
    padding: 4rem 0;
    display: grid;
    gap: 2rem;
}
.cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
}
.card {
    background: var(--card-bg);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.04);
}
.card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
}
.card p {
    margin-bottom: 1.5rem;
    color: var(--text-light);
    line-height: 1.8;
}

.cta-section {
    padding: 3rem 0;
}
.cta-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    background: linear-gradient(90deg, rgba(255,255,255,1) 0%, rgba(255,243,236,1) 100%);
    border: 1px solid rgba(249, 115, 22, 0.15);
    border-radius: 24px;
    padding: 2rem 2.5rem;
}
.section-label {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    color: var(--brand-orange);
    margin-bottom: 0.75rem;
}
    .heading-underline {
        position: relative;
        display: inline-block;
        padding-bottom: 0.6rem;
    }
    .heading-underline::after {
        content: none;
        background-image: none;
    }
    .heading-underline:hover::after {
        opacity: 1;
    }
    .funds-section {
        padding: 4rem 0;
        background: var(--bg-light);
    }
.section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
}
.section-header span {
    display: block;
    color: var(--text-light);
    margin-bottom: 0.5rem;
}
.section-header h2 {
    font-size: 2rem;
    margin: 0;
}
.fund-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
}
.fund-card {
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 1.75rem;
}
.fund-card h4 {
    margin-bottom: 0.85rem;
}
.fund-card p {
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
}
.fund-card strong {
    font-size: 1.1rem;
    color: var(--brand-green);
}

/* Hover scale for fund cards */
.fund-card {
    transition: transform 220ms ease, box-shadow 220ms ease;
    will-change: transform;
}
.fund-card:hover {
    transform: scale(1.02);
    box-shadow: 0 30px 60px rgba(2,6,23,0.12);
}

/* Dim orange hover for all cards */
.card,
.fund-card,
.cta-card,
.newsletter-card {
    transition: background-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
}
.card:hover,
.fund-card:hover,
.cta-card:hover,
.newsletter-card:hover {
    background-color: rgba(249,115,22,0.06); /* dim orange */
    border-color: rgba(249,115,22,0.12);
}

/* Use dim green for fund cards specifically */
.fund-card:hover {
    background-color: rgba(5,150,105,0.06); /* dim green */
    border-color: rgba(5,150,105,0.12);
}

.newsletter-section {
    padding: 4rem 0 6rem;
}
.newsletter-card {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
    align-items: center;
    background: #111827;
    color: white;
    border-radius: 28px;
    padding: 2.5rem;
}
.newsletter-card span {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    opacity: 0.85;
}
.newsletter-card h2 {
    margin: 0.75rem 0 0;
    font-size: 2rem;
    line-height: 1.2;
}
.newsletter-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
}
.newsletter-actions input {
    flex: 1;
    min-width: 240px;
    border: none;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    font-size: 1rem;
}

/* Hover scale for subscribe button inside newsletter actions */
.newsletter-actions a,
.newsletter-actions button {
    transition: transform 200ms ease, box-shadow 200ms ease;
}
.newsletter-actions a:hover,
.newsletter-actions button:hover {
    transform: scale(1.06);
    box-shadow: 0 18px 36px rgba(2,6,23,0.12);
}

.site-footer {
    padding: 4rem 0 3rem;
    background: #072544; /* dark blue */
    color: #e6f2fb; /* light blue/near-white text */
}
.footer-top {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: center;
    border-bottom: 1px solid rgba(230, 242, 251, 0.08);
    padding-bottom: 2rem;
    margin-bottom: 2rem;
}
.social-group,
.download-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.social-links,
.download-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}
.social-links a,
.footer-links a {
    color: inherit;
    text-decoration: none;
    font-weight: 500;
}
.social-links a:hover,
.footer-links a:hover {
    color: var(--brand-orange);
}
.footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
    color: rgba(230,242,251,0.85);
    margin-bottom: 1.75rem;
}
.footer-copy {
    display: grid;
    gap: 1rem;
    color: rgba(230,242,251,0.8);
    font-size: 0.95rem;
    line-height: 1.7;
}

@media (max-width: 1080px) {
    .hero-container,
    .newsletter-card,
    .cta-card,
    .section-header {
        grid-template-columns: 1fr;
    }
    .trust-grid,
    .cards-grid,
    .fund-grid {
        grid-template-columns: 1fr;
    }
    .cta-card,
    .newsletter-card {
        text-align: center;
    }
    .newsletter-actions {
        justify-content: center;
    }
}

@media (max-width: 768px) {
    .hero-section { padding-top: 3.5rem; }
    .hero-content h1 { font-size: 2.8rem; }
    .hero-stats { justify-content: center; }
    .hero-image img { max-width: 100%; }
    .feature-section.moved-feature .feature-container,
    .cta-card,
    .newsletter-card,
    .section-header,
    .footer-top {
        grid-template-columns: 1fr;
        text-align: center;
    }
    .feature-section.moved-feature .feature-image,
    .feature-section.moved-feature .feature-content,
    .footer-top,
    .footer-links {
        justify-content: center;
        align-items: center;
    }
    .feature-section.moved-feature .feature-image {
        margin: 0 auto;
    }
    .cta-card {
        flex-direction: column;
    }
    .newsletter-actions {
        justify-content: center;
    }
    .footer-top {
        padding-bottom: 1.5rem;
    }
}
</style>