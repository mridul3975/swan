---
// src/pages/index.astro
import BaseLayout from '../components/BaseLayout.astro';
import FeatureSection from '../components/FeatureSection.astro';
import Header from '../components/Header.astro';
---


<BaseLayout title="Scripbox - Invest in the best mutual funds">
    <Header />
    
    <main>
        <!-- HERO SECTION -->
        <section class="hero-section">
            <div class="container hero-container">
                <div class="hero-content">
                    <h1>
                        Grow wealth.<br>
                        Achieve goals.<br>
                        Invest in the best mutual funds.
                    </h1>
                    <div class="app-buttons">
                        <a href="#"><img src="/images/app-store.svg" alt="Download on the App Store"></a>
                        <a href="#"><img src="/images/play-store.svg" alt="Get it on Google Play"></a>
                    </div>
                    <div class="stats">
                        <div>
                            <strong>4 lac+</strong>
                            <span>Investors</span>
                        </div>
                        <div>
                            <strong>3,500 Cr</strong>
                            <span>AUM</span>
                        </div>
                        <div>
                            <strong>50,000 Cr+</strong>
                            <span>In wealth</span>
                        </div>
                    </div>
                </div>
                <div class="hero-image">
                    <img src="/images/Hero Phone.png" alt="Scripbox app on a phone">
                </div>
            </div>
        </section>
        
        <!-- We will add more sections here -->
             <!-- EXPERIENCE SECTION -->
    <section class="experience-intro">
        <div class="container">
            <h3>Experience the Scripbox difference.</h3>
            <p>Scripbox removes the guesswork, provides you the confidence, and helps you stay on track to achieve your financial goals.</p>
        </div>
    </section>

        <!-- FEATURE SECTIONS -->
    <FeatureSection
        title="Grow wealth."
        description="Scripbox helps you select the right mix of funds to grow your wealth steadily. We continuously monitor and manage your portfolio to keep it on track."
        imgSrc="/images/Feature 1 Phone Mockup.png"
        imgAlt="Grow wealth screen"
        imageSide="right"
    />
    </main>
</BaseLayout>

<style>

.experience-intro {
    padding: 6rem 0 0;
    text-align: center;
    background-color: var(--bg-light);
}
.experience-intro h3 {
    font-size: 2.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
}
.experience-intro p {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-light);
    line-height: 1.7;
}
    .hero-section {
        padding: 5rem 0;
    }
    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 2rem;
    }
    h1 {
        font-size: 2.8rem;
        font-weight: 600;
        line-height: 1.3;
        margin-bottom: 2rem;
    }
    .app-buttons {
        display: flex;
        gap: 1rem;
        margin-bottom: 3rem;
    }
    .app-buttons img {
        height: 45px;
    }
    .stats {
        display: flex;
        gap: 3rem;
        border-top: 1px solid var(--border-color);
        padding-top: 1.5rem;
    }
    .stats div {
        display: flex;
        flex-direction: column;
    }
    .stats strong {
        font-size: 1.5rem;
        font-weight: 600;
    }
    .stats span {
        color: var(--text-light);
        font-size: 0.9rem;
    }
    .hero-image {
        display: flex;
        justify-content: center;
    }
    .hero-image img {
        max-width: 350px;
    }

    /* Responsive for Hero */
    @media (max-width: 992px) {
        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .hero-image {
            order: -1; /* Move image to the top on mobile */
            margin-bottom: 3rem;
        }
        .app-buttons, .stats {
            justify-content: center;
        }
    }
</style>